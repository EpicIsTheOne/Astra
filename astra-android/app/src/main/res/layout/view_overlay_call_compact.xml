<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutOverlayCallCompact"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingTop="10dp"
    android:paddingEnd="14dp"
    android:paddingBottom="10dp"
    android:background="@drawable/bg_astra_panel"
    android:elevation="18dp">

    <View
        android:id="@+id/viewOverlayCallDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_astra_orb" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvOverlayCallPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call live"
            android:textColor="#F8FAFC"
            android:textStyle="bold"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvOverlayCallTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="00:00"
            android:textColor="#C4B5FD"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvOverlayCallHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_astra_chip"
        android:paddingLeft="10dp"
        android:paddingTop="5dp"
        android:paddingRight="10dp"
        android:paddingBottom="5dp"
        android:text="Double tap to end"
        android:textColor="#DDD6FE"
        android:textSize="11sp" />
</LinearLayout>
