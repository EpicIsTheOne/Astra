{
  "name": "astra-windows",
  "version": "0.1.0",
  "private": true,
  "description": "Astra desktop client for Windows",
  "author": "Epic",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win nsis portable"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.astra.desktop",
    "productName": "Astra",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Astra-Installer-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "shortcutName": "Astra",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "Astra-Portable-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "EpicIsTheOne",
      "repo": "Astra"
    }
  }
}
