<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Astra Wake-Up MVP"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Set daily wake to 5:50 AM ET and test now."
        android:textSize="16sp" />

    <EditText
        android:id="@+id/etApiUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="OpenClaw wake API URL"
        android:singleLine="true"
        android:text="http://127.0.0.1:8787/api/wakeup/line" />

    <CheckBox
        android:id="@+id/cbRandomSfx"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enable random annoying SFX" />

    <CheckBox
        android:id="@+id/cbPunish"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable punishment mode" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Save settings" />

    <Button
        android:id="@+id/btnCheckApi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Check server connection" />

    <TextView
        android:id="@+id/tvApiStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="API status: unknown"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnSchedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Schedule 5:50 AM" />

    <Button
        android:id="@+id/btnTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Test wake screen" />
</LinearLayout>
